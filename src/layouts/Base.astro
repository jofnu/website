---
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";
import {
  CEO_LINKEDIN,
  CEO_NAME,
  COMPANY_EMAIL,
  COMPANY_GITHUB,
  COMPANY_LINKEDIN,
  COMPANY_NAME,
  TECHNICAL_STACK,
} from "../lib/constants";

interface Props {
  title: string;
  description: string;
  lang?: "fr" | "en";
  ogImage?: string;
  altHref?: string | null;
  altLang?: "fr" | "en";
}

const {
  title,
  description,
  lang = (Astro.currentLocale as "fr" | "en") ?? "fr",
  ogImage = "/og.png",
  altHref,
  altLang,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = new URL(ogImage, Astro.site).href;
const skip = lang === "en" ? "Skip to content" : "Aller au contenu";

const orgLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: COMPANY_NAME,
  url: Astro.site?.href,
  email: COMPANY_EMAIL,
  description,
  address: {
    "@type": "PostalAddress",
    streetAddress: "60 rue François 1er",
    postalCode: "75008",
    addressLocality: "Paris",
    addressCountry: "FR",
  },
  areaServed: "FR",
  founder: { "@type": "Person", name: CEO_NAME, sameAs: CEO_LINKEDIN },
  knowsAbout: [
    "Produits IA",
    "Architectures multi-agents",
    "RAG",
    "MCP",
    "Applications web & mobiles",
    "Cloud",
    ...TECHNICAL_STACK,
  ],
  sameAs: [COMPANY_LINKEDIN, COMPANY_GITHUB, CEO_LINKEDIN],
};
---

<!doctype html>
<html lang={lang} class="no-js">
  <head>
    <script is:inline>
      document.documentElement.classList.remove("no-js");
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <link rel="alternate" hreflang={lang} href={canonical} />
    {
      altHref && altLang && (
        <link
          rel="alternate"
          hreflang={altLang}
          href={new URL(altHref, Astro.site).href}
        />
      )
    }

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === "en" ? "en_US" : "fr_FR"} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link
      rel="preload"
      href="/fonts/instrument-serif-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={COMPANY_NAME}
      href={lang === "en" ? "/en/rss.xml" : "/rss.xml"}
    />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(orgLd)}
    />

    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <a class="skip" href="#main">{skip}</a>
    <Header altHref={altHref} />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
