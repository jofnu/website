---
import Base from "../layouts/Base.astro";
// Single static 404 served by nginx for every path → bilingual, switch hidden.
---

<Base
  title="404 — Jofnu"
  description="Page introuvable / Page not found"
  altHref={null}
>
  <section class="wrap nf">
    <p class="meta">Erreur 404</p>
    <h1>Page introuvable.</h1>
    <p class="sub">
      Cette page n'existe pas ou a été déplacée.<br />
      <span class="en">This page doesn't exist or has moved.</span>
    </p>
    <p class="links">
      <a href="/">Accueil <span class="arrow">→</span></a>
      <a href="/en/">Home <span class="arrow">→</span></a>
      <a href="/blog">Blog</a>
    </p>
  </section>
</Base>

<style>
  .nf {
    padding-block: clamp(4rem, 14vh, 9rem);
  }

  h1 {
    margin-top: 1rem;
  }

  .sub {
    margin-top: 1.5rem;
    color: var(--ink-soft);
    font-size: 1.15rem;
  }

  .en {
    color: var(--ink-soft);
    opacity: 0.8;
  }

  .links {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: clamp(1rem, 3vw, 2rem);
  }

  .links a {
    font-weight: 600;
    text-decoration: none;
  }
</style>
