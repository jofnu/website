---
import { ui, getLang } from "../i18n/ui";
import { getPosts } from "../lib/posts";
import PostCard from "./PostCard.astro";

const lang = getLang(Astro.currentLocale);
const t = ui[lang].articles;
const blog = lang === "fr" ? "/blog" : "/en/blog";
const posts = (await getPosts(lang)).slice(0, 3);
---

<section class="articles wrap">
  <div class="head">
    <h2>{t.heading}</h2>
    <a class="all u-link" href={blog}>{t.all} <span class="arrow">→</span></a>
  </div>
  {
    posts.length > 0 ? (
      <div class="list">
        {posts.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    ) : (
      <p class="empty serif">{t.empty}</p>
    )
  }
</section>

<style>
  .articles {
    padding-block: clamp(2rem, 6vw, 5rem);
  }

  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .all {
    text-decoration: none;
    font-weight: 600;
  }

  .list {
    margin-top: 1.5rem;
    border-bottom: 1px solid var(--line);
  }

  .empty {
    margin-top: 1.5rem;
    font-size: 1.4rem;
    color: var(--ink-soft);
  }
</style>
