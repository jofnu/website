---
import { ui, getLang } from "../i18n/ui";
import { COMPANY_EMAIL, COMPANY_NAME } from "../lib/constants";
import LangSwitch from "./LangSwitch.astro";

interface Props {
  altHref?: string | null;
}
const { altHref } = Astro.props;
const lang = getLang(Astro.currentLocale);
const t = ui[lang];
const home = lang === "fr" ? "/" : "/en/";
const blog = lang === "fr" ? "/blog" : "/en/blog";
---

<header class="hd wrap">
  <a class="brand" href={home}>{COMPANY_NAME}</a>
  <nav class="nav">
    <a class="u-link" href={blog}>{t.nav.blog}</a>
    <a class="u-link" href={`mailto:${COMPANY_EMAIL}`}>{t.nav.contact}</a>
    <LangSwitch href={altHref} />
  </nav>
</header>

<style>
  .hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1.5rem;
  }

  .brand {
    font-family: var(--serif);
    font-size: 1.5rem;
    color: var(--ink);
    text-decoration: none;
    letter-spacing: -0.01em;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 3vw, 2rem);
  }

  .nav a {
    color: var(--ink);
    text-decoration: none;
    font-size: 0.95rem;
  }

  .nav a:hover {
    color: var(--accent);
  }
</style>
