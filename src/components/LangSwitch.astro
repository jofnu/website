---
import { getLang } from "../i18n/ui";

// Links to the mirror of the current page in the other language.
// `href`:
//   undefined → auto-compute the mirror path (landing, blog index…)
//   string    → use it (explicit translation URL)
//   null      → no translation exists → render nothing
interface Props {
  href?: string | null;
}
const lang = getLang(Astro.currentLocale);
const path = Astro.url.pathname;

const auto =
  lang === "fr"
    ? "/en" + (path === "/" ? "/" : path)
    : path.replace(/^\/en/, "") || "/";

const { href } = Astro.props;
const target = href === undefined ? auto : href;
const other = lang === "fr" ? "EN" : "FR";
---

{
  target && (
    <a class="lang" href={target} hreflang={lang === "fr" ? "en" : "fr"}>
      {other}
    </a>
  )
}

<style>
  .lang {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    text-decoration: none;
  }
  .lang:hover {
    color: var(--accent);
  }
</style>
