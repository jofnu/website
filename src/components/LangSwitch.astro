---
import { getLang } from "../i18n/ui";

// Links to the mirror of the current page in the other language.
// Optional `href` overrides the auto-computed target (used by blog posts
// to hide the switch when no translation exists).
interface Props {
  href?: string;
}
const lang = getLang(Astro.currentLocale);
const path = Astro.url.pathname;

const auto =
  lang === "fr"
    ? "/en" + (path === "/" ? "/" : path)
    : path.replace(/^\/en/, "") || "/";

const { href = auto } = Astro.props;
const other = lang === "fr" ? "EN" : "FR";
---

<a class="lang" href={href} hreflang={lang === "fr" ? "en" : "fr"}>{other}</a>

<style>
  .lang {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-soft);
    text-decoration: none;
  }
  .lang:hover {
    color: var(--accent);
  }
</style>
