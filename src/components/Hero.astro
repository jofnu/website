---
import { ui, getLang } from "../i18n/ui";
import Typewriter from "./Typewriter.astro";
import Button from "./Button.astro";

const lang = getLang(Astro.currentLocale);
const t = ui[lang].hero;
---

<section class="hero wrap">
  <p class="meta">{t.eyebrow}</p>
  <h1 class="title">
    <span class="title-live">
      {t.prefix}{" "}
      <span class="accent"><Typewriter phrases={[...t.phrases]} /></span>
    </span>
    {
      t.phrases.map((p) => (
        <span class="title-ghost" aria-hidden="true">
          {t.prefix} {p}
        </span>
      ))
    }
  </h1>
  <p class="manifesto serif">{t.manifesto}</p>
  <p class="subtitle">{t.subtitle}</p>
  <p class="cta-row">
    <Button href="#contact">{t.cta} →</Button>
  </p>
</section>

<style>
  .hero {
    padding-block: clamp(3rem, 9vh, 7rem) clamp(3rem, 8vh, 6rem);
  }

  h1 {
    margin-top: 1rem;
    max-width: 18ch;
  }

  /* All phrases stack in one grid cell → height = tallest; live text overlays. */
  .title {
    display: grid;
  }

  .title > * {
    grid-area: 1 / 1;
  }

  .title-ghost {
    visibility: hidden;
  }

  .accent :global(.tw-text) {
    color: var(--accent);
  }

  .manifesto {
    margin-top: 2rem;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.2;
    max-width: 24ch;
    color: var(--ink);
  }

  .subtitle {
    margin-top: 1.5rem;
    max-width: 52ch;
    color: var(--ink-soft);
    font-size: 1.15rem;
  }

  .cta-row {
    margin-top: 2.5rem;
  }

  /* Load stagger: only when JS is on (class removed pre-paint) and motion allowed. */
  @media (prefers-reduced-motion: no-preference) {
    :global(html:not(.no-js)) .hero > * {
      opacity: 0;
      animation: hero-in 0.6s ease forwards;
    }
    :global(html:not(.no-js)) .hero > :nth-child(1) {
      animation-delay: 0.05s;
    }
    :global(html:not(.no-js)) .hero > :nth-child(2) {
      animation-delay: 0.15s;
    }
    :global(html:not(.no-js)) .hero > :nth-child(3) {
      animation-delay: 0.25s;
    }
    :global(html:not(.no-js)) .hero > :nth-child(4) {
      animation-delay: 0.35s;
    }
    :global(html:not(.no-js)) .hero > :nth-child(5) {
      animation-delay: 0.45s;
    }
  }

  @keyframes hero-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
</style>
