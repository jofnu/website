---
import { ui, getLang } from "../i18n/ui";
import Reveal from "./Reveal.astro";

const lang = getLang(Astro.currentLocale);
const t = ui[lang].parcours;
---

<section class="parcours wrap">
  <h2>{t.heading}</h2>
  <p class="lead serif">{t.lead}</p>

  <div class="highlights">
    {
      t.highlights.map((h, i) => (
        <Reveal delay={i * 0.07}>
          <div class="hl">
            <p class="k">{h.k}</p>
            <p class="v">{h.v}</p>
          </div>
        </Reveal>
      ))
    }
  </div>

  <p class="meta stack-label">{t.stackLabel}</p>
  <ul class="stack">
    {t.stack.map((s) => <li>{s}</li>)}
  </ul>
</section>

<style>
  .parcours {
    padding-block: clamp(2rem, 6vw, 5rem);
  }

  .lead {
    margin-top: 1rem;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.25;
    max-width: 30ch;
    color: var(--ink);
  }

  .highlights {
    margin-top: clamp(2rem, 5vw, 3.5rem);
    display: grid;
    gap: var(--gap);
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
  }

  .k {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1;
  }

  .v {
    margin-top: 0.4rem;
    color: var(--ink-soft);
  }

  .stack-label {
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }

  .stack {
    margin-top: 1rem;
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .stack li {
    border: 1px solid var(--line);
    padding: 0.3rem 0.7rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.03em;
  }
</style>
