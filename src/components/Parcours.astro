---
import { ui, getLang } from "../i18n/ui";
import Reveal from "./Reveal.astro";

const lang = getLang(Astro.currentLocale);
const t = ui[lang].parcours;
---

<section class="parcours wrap">
  <h2>{t.heading}</h2>
  <p class="lead serif">{t.lead}</p>

  <div class="highlights">
    {
      t.highlights.map((h, i) => (
        <Reveal delay={i * 0.07}>
          <div class="hl">
            <p class="k">{h.k}</p>
            <p class="v">{h.v}</p>
          </div>
        </Reveal>
      ))
    }
  </div>

  <p class="meta trust-label">{t.trust.heading}</p>
  <ul class="clients">
    {
      t.trust.clients.map((c) => (
        <li>
          <a href={c.url} target="_blank" rel="noopener noreferrer">
            {c.name}
          </a>
        </li>
      ))
    }
  </ul>

  <p class="meta stack-label">{t.stackLabel}</p>
  <div class="marquee">
    <ul class="stack" aria-label={t.stackLabel}>
      {
        [...t.stack, ...t.stack].map((s, i) => (
          <li aria-hidden={i >= t.stack.length ? "true" : undefined}>{s}</li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .parcours {
    padding-block: clamp(2rem, 6vw, 5rem);
  }

  .lead {
    margin-top: 1rem;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    line-height: 1.25;
    max-width: 30ch;
    color: var(--ink);
  }

  .highlights {
    margin-top: clamp(2rem, 5vw, 3.5rem);
    display: grid;
    gap: var(--gap);
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
  }

  .k {
    font-family: var(--serif);
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    line-height: 1;
  }

  .v {
    margin-top: 0.4rem;
    color: var(--ink-soft);
  }

  .stack-label,
  .trust-label {
    margin-top: clamp(2.5rem, 5vw, 4rem);
  }

  .clients {
    margin-top: 1rem;
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .clients li a {
    display: block;
    border: 1px solid var(--line);
    padding: 0.3rem 0.7rem;
    font-size: 0.95rem;
    font-weight: 600;
    color: inherit;
    text-decoration: none;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .clients li a:hover {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  /* Edge fade so tags slide in/out softly instead of being hard-clipped. */
  .marquee {
    margin-top: 1rem;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent,
      #000 6%,
      #000 94%,
      transparent
    );
    mask-image: linear-gradient(
      90deg,
      transparent,
      #000 6%,
      #000 94%,
      transparent
    );
  }

  .stack {
    list-style: none;
    padding: 0;
    display: flex;
    width: max-content;
    animation: marquee 30s linear infinite;
  }

  .marquee:hover .stack {
    animation-play-state: paused;
  }

  /* Trailing margin (not flex gap) so the two copies tile seamlessly at -50%. */
  .stack li {
    margin-right: 0.5rem;
    border: 1px solid var(--line);
    padding: 0.3rem 0.7rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    white-space: nowrap;
    transition:
      background 0.2s ease,
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .stack li:hover {
    background: var(--accent);
    color: var(--bg);
    border-color: var(--accent);
  }

  @keyframes marquee {
    to {
      transform: translateX(-50%);
    }
  }

  /* No animation → wrap statically and drop the duplicate set. */
  :global(html.no-js) .stack {
    flex-wrap: wrap;
    width: auto;
    animation: none;
  }

  :global(html.no-js) .stack li[aria-hidden] {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee {
      mask-image: none;
      -webkit-mask-image: none;
    }

    .stack {
      flex-wrap: wrap;
      width: auto;
      animation: none;
    }

    .stack li[aria-hidden] {
      display: none;
    }
  }
</style>

<script>
  // Count numeric highlights up from 0 when they scroll into view.
  import { animate, inView } from "motion";

  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  document.querySelectorAll<HTMLElement>(".k").forEach((el) => {
    const m = (el.textContent ?? "").match(/^(\d+)(.*)$/s);
    if (!m || reduce) return;

    const target = Number(m[1]);
    const suffix = m[2];
    el.textContent = `0${suffix}`;

    const stop = inView(
      el,
      () => {
        animate(0, target, {
          duration: 1.2,
          ease: "easeOut",
          onUpdate: (v) => {
            el.textContent = `${Math.round(v)}${suffix}`;
          },
        });
        stop();
      },
      { amount: 0.6 },
    );
  });
</script>
